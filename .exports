#!/usr/bin/env bash

# Default editor
export EDITOR='vim'

# Java (asdf sets JAVA_HOME dynamically; only prepend if set)
[ -n "${JAVA_HOME:-}" ] && export PATH="$JAVA_HOME/bin:$PATH"

# Node REPL
export NODE_REPL_HISTORY="$HOME/.node_history"
export NODE_REPL_HISTORY_SIZE='32768'
export NODE_REPL_MODE='sloppy'

# Python
export PYTHONIOENCODING='UTF-8'

# History (bash; zsh uses setopt in .zshrc)
export HISTSIZE='32768'
export HISTFILESIZE="$HISTSIZE"
export HISTCONTROL='ignoreboth'

# Locale
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

# Manpage highlighting (fallback to yellow via tput if $yellow unset)
export LESS_TERMCAP_md="${yellow:-$(tput setaf 3 2>/dev/null || true)}"

# Don’t clear screen after quit
export MANPAGER='less -X'

# gpg fix
export GPG_TTY="$(tty)"

# Hide bash deprecation warning
export BASH_SILENCE_DEPRECATION_WARNING=1

# -------- Architecture-aware Homebrew prefix ---------------------------------
# Intel = /usr/local, Apple Silicon = /opt/homebrew
if [[ "$(uname -m)" == "arm64" ]]; then
  __BREW_PREFIX="/opt/homebrew"
else
  __BREW_PREFIX="/usr/local"
fi
# If brew is available, prefer its dynamic prefix
if command -v brew >/dev/null 2>&1; then
  __BREW_PREFIX="$(brew --prefix 2>/dev/null || echo "$__BREW_PREFIX")"
fi

# Android dev (keep your values; only the Homebrew-based paths vary by arch)
export ANDROID_HOME="$HOME/Library/Android/sdk"
export ANDROID_NDK_HOME="$__BREW_PREFIX/opt/android-ndk"
export ANDROID_SDK_ROOT="$__BREW_PREFIX/share/android-sdk"

# Ruby build flags (openssl@3 is the current Homebrew default for Ventura+)
__OPENSSL_PREFIX="$( (brew --prefix openssl@3 2>/dev/null) || echo "$__BREW_PREFIX/opt/openssl@3" )"
export RUBY_CONFIGURE_OPTS="--with-openssl-dir=${__OPENSSL_PREFIX}"

unset __BREW_PREFIX __OPENSSL_PREFIX
